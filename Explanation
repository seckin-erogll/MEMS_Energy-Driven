     Final `forward()` method:
     ```python
     def forward(self, x: torch.Tensor):
         xi = x[..., 0:1]  # ξ ∈ (0,1)

         # Denormalize ag
         ag_lo  = 5.0e-6
         ag_hi  = 15.0e-6
         ag_hat = x[..., 6:7]
         ag_phys = ag_hat * (ag_hi - ag_lo) + ag_lo  # exact physical ag [m]

         W_ref = ag_phys
         U_ref = 0.1 * ag_phys

         h = self.trunk(x)
         w_raw = self.head_w(h)  # unbounded
         u_raw = self.head_u(h)  # unbounded

         # Clamped BC: w(1)=0, w'(1)=0
         bc_w = (1.0 - xi**2) ** 2
         w_profile = bc_w * w_raw * W_ref

         # Hard contact: w ≥ -ag via smooth-max
         eps_c = 5e-8  # 50 nm
         contact_floor = -ag_phys
         diff = w_profile - contact_floor
         w = 0.5 * (w_profile + contact_floor
                    + torch.sqrt(diff**2 + eps_c**2))

         # In-plane BC: u(0)=u(1)=0
         bc_u = xi * (1.0 - xi)
         u = bc_u * u_raw * U_ref

         return w, u
     ```

